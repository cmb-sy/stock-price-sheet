# Secrets — never commit the service-account key
*.json
.env
.env.*

# Local agent / handover session state (generated by Claude Code skills, local-only)
.agents/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Google Apps Script (webapp). .clasp.json holds the scriptId linkage and is
# already matched by *.json above — keep it local. The appsscript.json manifest is
# safe (no secrets/tickers) and must be committed, so re-include it:
!webapp/appsscript.json

# Local design / reference artifacts under webapp/ — NOT part of the deployed app
# (clasp pushes only .gs/.html/appsscript.json). Keep them out of this public repo: a
# design or screenshot file can embed real tickers/prices/PII, and committing anything
# under webapp/ would trigger a needless production deploy (deploy-webapp.yml: webapp/**).
webapp/*.pen
webapp/*.png
